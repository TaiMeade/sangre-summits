# EmailJS credentials — copy this file to ".env" and paste your real values.
# Sign up at https://www.emailjs.com/ , add an email service + template, then
# grab these three values from your dashboard. The contact form stays disabled
# (shows a friendly "not configured" notice) until all three are filled in.

VITE_EMAILJS_SERVICE_ID=your_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_template_id_here
VITE_EMAILJS_PUBLIC_KEY=your_public_key_here
